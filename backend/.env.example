# ===========================================
# SharpChoice Real Estate - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===========================================
# Email Service (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key_here

# ===========================================
# Server Configuration
# ===========================================
PORT=3000

# ===========================================
# Google Business Profile Integration
# ===========================================
# Option 1: Service Account (RECOMMENDED for production)
# - Create a service account in Google Cloud Console
# - Enable Google Business Profile API
# - Download the JSON key file
# - Extract client_email and private_key

GOOGLE_BUSINESS_ACCOUNT_ID=accounts/your_account_id_here
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option 2: API Key (Fallback - less secure, not recommended for production)
# Comment out the service account variables above and use these instead:
# GOOGLE_BUSINESS_ACCOUNT_ID=your_account_id_here
# GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# Notes:
# ===========================================
# - For GOOGLE_PRIVATE_KEY: Replace actual newlines with \n
# - The service account must have access to your Google Business Profile
# - Required API scope: https://www.googleapis.com/auth/business.manage
# - Keep your .env file secure and never commit it to version control
